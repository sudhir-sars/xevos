{
  "name": "xevos",
  "version": "0.1.0",
  "description": "",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "scripts": {
    "core:dev": "pnpm --filter @xevos/core dev",
    "core:build": "pnpm --filter @xevos/core build",
    "core:start": "pnpm --filter @xevos/core start",
    "web:dev": "pnpm --filter @xevos/web dev",
    "web:build": "pnpm --filter @xevos/web build",
    "dev": "pnpm --parallel --filter @xevos/core --filter @xevos/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
