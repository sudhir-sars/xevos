{
  "name": "@xevos/core",
  "version": "0.1.0",
  "description": "Xevos multi-agent core: repositories, services, EventBus, Principal, and the observer/WebSocket tap.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./protocol": "./src/observer/protocol.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@qdrant/js-client-rest": "^1.18.0",
    "ai": "^6.0.208",
    "dotenv": "^17.4.2",
    "exa-js": "^2.15.0",
    "fast-bm25": "^0.0.5",
    "lowdb": "^7.0.1",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
