{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    // DOM lib so the in-page page.evaluate / $$eval callbacks type-check
    // (they run in the browser); node types for the rest.
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
